# Polymarket (required for trading, not for scanning)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Anthropic (required for prediction calibration)
ANTHROPIC_API_KEY=

# Reddit (required for research agent)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymarket-bot/1.0

# Twitter/X (optional - twscrape uses account pool)
# Configured via twscrape CLI: twscrape add_accounts

# Risk parameters
MAX_BET_FRACTION=0.05
MIN_EDGE_THRESHOLD=0.08
CONFIDENCE_THRESHOLD=0.7
MAX_DAILY_LOSS=100.0
BANKROLL=1000.0

# Scanner parameters
MIN_LIQUIDITY=5000.0
MIN_VOLUME_24H=1000.0
MAX_DAYS_TO_RESOLUTION=90
SPREAD_ALERT_THRESHOLD=0.10
PRICE_MOVE_ALERT_THRESHOLD=0.15

# Model hyperparameters
XGB_N_ESTIMATORS=100
XGB_MAX_DEPTH=4
XGB_LEARNING_RATE=0.1

# NewsAPI (free tier: 100 req/day, top-headlines only)
NEWSAPI_KEY=

# Research
RSS_ENTRY_LIMIT=20

# FRED economic data (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Sentiment LLM (Haiku replaces VADER for ambiguous texts)
SENTIMENT_MODEL=claude-haiku-4-5-20251001
SENTIMENT_USE_LLM=true
SENTIMENT_LLM_THRESHOLD=0.4

# Research source weights (0 < weight <= 1.0)
# SOURCE_WEIGHT_NEWSAPI=1.0
# SOURCE_WEIGHT_RSS_MAJOR=0.9
# SOURCE_WEIGHT_RSS_PREDICTION=0.8
# SOURCE_WEIGHT_RSS_GOOGLE=0.7
# SOURCE_WEIGHT_TWITTER=0.5
# SOURCE_WEIGHT_REDDIT=0.6
# SOURCE_WEIGHT_METACULUS=0.9
# SOURCE_WEIGHT_PREDICTIT=0.85
# SOURCE_WEIGHT_WIKIPEDIA=0.7
# RESEARCH_TIMEOUT=10

# Operational
LOG_LEVEL=INFO
LOOP_INTERVAL=300

# Database path (relative to working directory)
DB_PATH=data/polymarket.db

# Telegram notifications (create bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=
