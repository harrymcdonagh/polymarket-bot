# Polymarket (required for trading, not for scanning)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Anthropic (required for prediction calibration)
ANTHROPIC_API_KEY=

# Reddit (required for research agent)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymarket-bot/1.0

# Twitter/X (optional - twscrape uses account pool)
# Configured via twscrape CLI: twscrape add_accounts

# Risk parameters
MAX_BET_FRACTION=0.05
MIN_EDGE_THRESHOLD=0.08
CONFIDENCE_THRESHOLD=0.7
MAX_DAILY_LOSS=100.0
BANKROLL=1000.0

# Scanner parameters
MIN_LIQUIDITY=5000.0
MIN_VOLUME_24H=1000.0
MAX_DAYS_TO_RESOLUTION=90
SPREAD_ALERT_THRESHOLD=0.10
PRICE_MOVE_ALERT_THRESHOLD=0.15

# Model hyperparameters
XGB_N_ESTIMATORS=100
XGB_MAX_DEPTH=4
XGB_LEARNING_RATE=0.1

# Research
RSS_ENTRY_LIMIT=20
SENTIMENT_AMBIGUITY_THRESHOLD=0.6

# Operational
LOG_LEVEL=INFO
LOOP_INTERVAL=300
